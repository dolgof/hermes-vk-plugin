# ═══════════════════════════════════════════════
# VK Plugin — Environment Variables
# ═══════════════════════════════════════════════
#
# ⚠️  Токены ТОЛЬКО в .env, не в конфиге!
#    См. config.example.yaml для остальных опций.

# ── Single-account ──────────────────────────────
# Обязательно: токен сообщества VK
VK_GROUP_TOKEN=vk1.a.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Multi-account ───────────────────────────────
# Токены для каждого аккаунта: VK_GROUP_TOKEN_{ID}
# ID — имя аккаунта из config.accounts в uppercase
# VK_GROUP_TOKEN_DEFAULT=vk1.a.xxxxxxxxxx
# VK_GROUP_TOKEN_SUPPORT=vk1.a.xxxxxxxxxx
# VK_GROUP_TOKEN_SALES=vk1.a.xxxxxxxxxx

# ── Доступ (legacy) ─────────────────────────────
# Список разрешённых пользователей (через запятую)
# VK_ALLOWED_USERS=12345,67890
# Разрешить всем
# VK_ALLOW_ALL_USERS=true

# ── Уведомления ─────────────────────────────────
# Канал для уведомлений от VK бота (peer_id)
# VK_HOME_CHANNEL=12345

# Telegram для уведомлений (если доступен)
# TELEGRAM_BOT_TOKEN=<BOT_TOKEN>
# TELEGRAM_HOME_CHANNEL=<CHAT_ID>
